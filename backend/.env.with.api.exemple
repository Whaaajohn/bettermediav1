NODE_ENV=production
LOCAL_DEV=false
HOST=your ip address or domain
PORT=5174
ADMIN_PORT=5175
API_BASE_URL=http://localhost:5174
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

JWT_SECRET=change_this_jwt_secret
JWT_EXPIRES_IN=7d
COOKIE_NAME=jwt
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
BCRYPT_ROUNDS=12
TRUST_PROXY=false

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_admin_password
ADMIN_EMAIL=admin@bettermedia.local
BOT_USERNAME=modbot
BOT_PASSWORD=change_this_bot_password
BOT_EMAIL=modbot@bettermedia.local

DB_DRIVER=mongo
MONGO_URI=your mongodb connection string make sure its mongodb community edition and not atlas
MONGO_MIGRATE_FROM_LOCAL_JSON=true
LOCAL_DB_FILE=./data/db.json
AUTO_BACKUP_DB=true
DB_BACKUP_DIR=./data/backups
DB_WRITE_MODE=queued

REDIS_ENABLED=true
REDIS_REQUIRED=true
REDIS_URL=your redis connection string for example redis://localhost:6379
REDIS_PREFIX=bettermedia:
USE_REDIS_SOCKET_ADAPTER=true
REDIS_SOCKET_ADAPTER=true
REDIS_RATE_LIMITS=true
REDIS_QUEUES=true

EMAIL_ENABLED=true
SMTP_ENABLED=true
SMTP_APP_NAME=Media
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_TIMEOUT_MS=15000
SMTP_USER=some email address you control for sending emails
SMTP_PASS=the password for that email address or an app password if using gmail
SMTP_FROM_NAME=Media
SMTP_FROM_EMAIL=the email address you want emails to come from, usually the same as SMTP_USER
MAIL_FROM_NAME=Media
MAIL_FROM_EMAIL=the email address you want emails to come from, usually the same as SMTP_USER
DEV_PRINT_EMAIL_CODES=false
LOGIN_ALERT_EMAILS=true
LOGIN_ALERT_TRUSTED_DEVICE_SKIP=false

UPLOAD_DRIVER=mongo
LOCAL_UPLOAD_DIR=./uploads
PUBLIC_UPLOAD_URL=http://localhost:5174/uploads
MAX_UPLOAD_MB=250

RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=20
POST_RATE_LIMIT_MAX=30
MESSAGE_RATE_LIMIT_MAX=80
UPLOAD_RATE_LIMIT_MAX=20
RATE_LIMIT_BYPASS_ADMIN=false
ENABLE_HELMET=true
ENABLE_COMPRESSION=true

MODERATION_ENABLED=true
AUTO_SPAM_DETECTION=true
DETECTION_PROVIDER=sightengine
DECISION_PROVIDER=sightengine_thresholds
APPEAL_REVIEWER=ollama_reasoning
SIGHTENGINE_ENABLED=true
SIGHTENGINE_API_USER=your sightengine api user
SIGHTENGINE_API_SECRET=your sightengine api secret
SIGHTENGINE_TIMEOUT_MS=20000
SIGHTENGINE_STRICTNESS=medium
SIGHTENGINE_TEXT_MODE=ml,rules
SIGHTENGINE_TEXT_ENDPOINT=https://api.sightengine.com/1.0/text/check.json
SIGHTENGINE_IMAGE_ENDPOINT=https://api.sightengine.com/1.0/check.json
SIGHTENGINE_MODELS=nudity-2.1,weapon,gore,offensive,scam,text-content,face-attributes
MAX_HASHTAGS_PER_POST=10
MAX_POST_LENGTH=2000
MAX_COMMENT_LENGTH=1000

BOT_ENGINE_ENABLED=true
BOT_LOCAL_AI_ENABLED=true
BOT_SCAN_POSTS=true
BOT_SCAN_COMMENTS=true
BOT_SCAN_MESSAGES=true
BOT_SCAN_IMAGES=true
BOT_SCAN_REPORTS=true
BOT_SCAN_APPEALS=true
ALLOW_BOT_AUTO_ACTIONS=true
BOT_CAN_WARN=true
BOT_CAN_CREATE_REPORTS=true
BOT_CAN_HIDE_CONTENT=true
BOT_CAN_TEMP_MUTE=true
BOT_CAN_TEMP_RESTRICT=true
BOT_CAN_TEMP_BAN=true
BOT_CAN_FULL_BAN=false
BOT_CAN_DELETE_USERS=false
BOT_CAN_CLEAR_LOGS=false
BOT_CAN_CHANGE_ADMIN=false

OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TEXT_MODEL=qwen2.5:3b
OLLAMA_FAST_CHAT_MODEL=qwen2.5:3b
OLLAMA_APPEAL_MODEL=phi4-mini:latest
OLLAMA_VISION_ENABLED=false
OLLAMA_MEMORY_ENABLED=true
OLLAMA_SOCIAL_MODE=true
OLLAMA_SOCIAL_COMMENTS_ENABLED=false
OLLAMA_TEMPERATURE=0.25
OLLAMA_NUM_PREDICT=120

ALGORITHM_ENABLED=true
FEED_CACHE_SECONDS=60
TRENDING_CACHE_SECONDS=120
MAX_CANDIDATE_POSTS=500
DEFAULT_FEED_LIMIT=20
EXPLORATION_PERCENT=10
FOLLOWING_PERCENT=35
LANGUAGE_PERCENT=25
TRENDING_PERCENT=10
NEW_USER_PERCENT=10
STAFF_PERCENT=5

SOCKET_IO_ENABLED=true
CALL_SIGNALING_ENABLED=true
STUN_URLS=stun:stun.l.google.com:19302
TURN_ENABLED=false
TURN_URL=
TURN_USERNAME=
TURN_PASSWORD=

WORKER_CPU_FRACTION=0.5
WORKER_MIN_PROCESSES=1
WORKER_MAX_PROCESSES=auto
WORKER_QUEUES_ENABLED=true

LOG_LEVEL=info
LOG_HTTP=true
LOG_SOCKET=true
