BOT_ENGINE_ENABLED=true
BOT_LOCAL_AI_ENABLED=true
BOT_SCAN_POSTS=true
BOT_SCAN_COMMENTS=true
BOT_SCAN_MESSAGES=true
BOT_SCAN_IMAGES=false
BOT_SCAN_REPORTS=true
BOT_SCAN_APPEALS=true
