NODE_ENV=development
LOCAL_DEV=true
HOST=your ip address or localhost
PORT=5174
ADMIN_PORT=5175
API_BASE_URL=http://localhost:5174
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

JWT_SECRET=local-dev-secret-change-if-you-share-this-pc
COOKIE_NAME=jwt
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin12345
ADMIN_EMAIL=admin@bettermedia.local
BOT_USERNAME=modbot
BOT_PASSWORD=modbot12345
BOT_EMAIL=modbot@bettermedia.local

DB_DRIVER=local_json
MONGO_URI=
MONGO_MODE=
MONGO_MIGRATE_FROM_LOCAL_JSON=false
LOCAL_DB_FILE=./data/db.json
AUTO_BACKUP_DB=true
DB_BACKUP_DIR=./data/backups

REDIS_ENABLED=false
REDIS_REQUIRED=false
REDIS_URL=
