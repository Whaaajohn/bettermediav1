RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=20
POST_RATE_LIMIT_MAX=30
MESSAGE_RATE_LIMIT_MAX=80
UPLOAD_RATE_LIMIT_MAX=20
